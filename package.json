{
  "name": "durationkit",
  "version": "0.1.0",
  "description": "Bidirectional duration parsing and formatting. Parse '2h 30m', '1.5 hours', '2:30:00', ISO 8601. Format ms to compact/long/colon/ISO. Zero dependencies.",
  "keywords": [
    "duration",
    "parse-duration",
    "format-duration",
    "humanize-duration",
    "time",
    "ms",
    "milliseconds",
    "iso-8601",
    "zero-dependency",
    "typescript"
  ],
  "author": "trananhtung",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trananhtung/durationkit.git"
  },
  "homepage": "https://github.com/trananhtung/durationkit#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
